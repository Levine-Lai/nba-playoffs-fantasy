{
  "name": "playoff-fantasy-nba",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "build": "npm run typecheck --prefix backend && npm run build --prefix frontend",
    "check": "npm run typecheck --prefix backend && npm run build --prefix frontend",
    "db:migrate:local": "npm run db:migrate:local --prefix backend",
    "db:migrate:remote": "npm run db:migrate:remote --prefix backend",
    "db:seed:from-local": "npm run db:seed:from-local --prefix backend",
    "db:seed:bootstrap": "npm run db:seed:bootstrap --prefix backend",
    "db:seed:live": "npm run db:seed:live --prefix backend",
    "db:seed:apply:local": "npm run db:seed:apply:local --prefix backend",
    "db:seed:apply:remote": "npm run db:seed:apply:remote --prefix backend",
    "start": "npm run dev:backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}

